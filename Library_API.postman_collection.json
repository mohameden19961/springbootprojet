{
	"info": {
		"name": "Library API",
		"description": "Collection Postman complète pour l'API de Gestion de Bibliothèque.\n\n## Authentification\n- Login avec abdy / 24068Supnum → récupérer le token\n- Définir la variable `token` manuellement ou via le script du login\n\n## Variables\n- `baseUrl`: `http://localhost:8081`\n- `token`: token JWT (défini automatiquement après login)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "library"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8081",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string"
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{token}}",
				"type": "string"
			}
		]
	},
	"item": [
		{
			"name": "Auth",
			"description": "Authentification publique",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('token', json.token);",
									"}",
									""
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"abdy\",\n    \"password\": \"24068Supnum\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "login"]
						},
						"description": "Authentification publique. Retourne un token JWT + username + role."
					},
					"response": [
						{
							"name": "Login Success",
							"body": "{\n    \"token\": \"eyJhbGci...\",\n    \"username\": \"abdy\",\n    \"role\": \"ADMIN\"\n}",
							"code": 200,
							"header": []
						},
						{
							"name": "Login Invalid",
							"body": "{\n    \"error\": \"Invalid credentials\"\n}",
							"code": 401,
							"header": []
						}
					]
				}
			]
		},
